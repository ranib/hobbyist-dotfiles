{
    "margin-top": 5,
    "margin-left": 5,
    "margin-right": 5,
    "layer": "top",
    "position": "top",
    "spacing": 6,
    "reload_style_on_change": true,

    "modules-left": [ "custom/logo","mpris","tray" ],

    "custom/logo": {
      "format" : "󰣇   DriftWM",
      "tooltip": false,
      "tooltip-format": "App launcher",
      "on-click": "pkill rofi || rofi -show drun",
      "on-click-right": "foot"
    },

    "include": ["~/.config/waybar/Modules/*.jsonc"]
}
