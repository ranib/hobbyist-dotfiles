input {
  keyboard {
    xkb {
      layout "us"
    }

    repeat-rate 60
    repeat-delay 300
  }

  touchpad {
    tap
    natural-scroll
    accel-speed 1.0
    accel-profile "adaptive"
    scroll-factor 2.0
    scroll-method "two-finger"
  }

  mouse {
    accel-speed 1.0
    accel-profile "adaptive"
    scroll-factor 2.0
  }

  focus-follows-mouse
}
